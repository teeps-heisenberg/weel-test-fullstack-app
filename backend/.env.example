# =============================================================================
# BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
#
# Copy this file to .env for local development without Docker
# For Docker setup, values are configured in docker-compose.yml

DATABASE_URL=postgresql://postgres:devpass@localhost:5432/delivery_db?schema=public
JWT_SECRET=your-secret-key-here
PORT=5000
NODE_ENV=development

# Google Gemini API Key (Required for AI summaries)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
